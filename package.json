{
  "name": "eslint-plugin-package-json",
  "version": "1.2.0",
  "description": "Rules for consistent, readable, and valid package.json files. 🗂️",
  "homepage": "https://github.com/michaelfaith/eslint-plugin-package-json#readme",
  "bugs": {
    "url": "https://github.com/michaelfaith/eslint-plugin-package-json/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelfaith/eslint-plugin-package-json.git"
  },
  "license": "MIT",
  "contributors": [
    {
      "name": "James Zetlen",
      "email": "zetlen@gmail.com"
    },
    {
      "name": "JoshuaKGoldberg",
      "email": "npm@joshuakgoldberg.com",
      "url": "https://joshuakgoldberg.com"
    },
    {
      "name": "michael faith",
      "url": "https://michael.faith"
    }
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.mts",
      "default": "./lib/index.mjs"
    },
    "./experimental": {
      "types": "./lib/experimental/index.d.mts",
      "default": "./lib/experimental/index.mjs"
    }
  },
  "main": "lib/index.mjs",
  "files": [
    "lib/"
  ],
  "scripts": {
    "build": "tsdown",
    "docs:generate": "pnpm build --no-dts && eslint-doc-generator",
    "format": "prettier .",
    "lint": "eslint . --max-warnings 0",
    "lint:knip": "knip",
    "site:build": "astro build",
    "site:dev": "astro dev",
    "site:preview": "astro preview",
    "site:sync": "astro sync",
    "site:typecheck": "pnpm site:sync && tsc --project site/tsconfig.json",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@altano/repository-tools": "^2.0.1",
    "change-case": "^5.4.4",
    "detect-indent": "^7.0.2",
    "detect-newline": "^4.0.1",
    "eslint-fix-utils": "~0.4.1",
    "eslint-json-compat-utils": "^0.2.3",
    "jsonc-eslint-parser": "^3.1.0",
    "package-json-validator": "^1.5.0",
    "semver": "^7.7.3",
    "sort-object-keys": "^2.0.0",
    "sort-package-json": "^3.4.0"
  },
  "devDependencies": {
    "@astrojs/starlight": "0.39.0",
    "@catppuccin/starlight": "2.0.1",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.0",
    "@eslint/js": "10.0.1",
    "@eslint/json": "2.0.0",
    "@eslint/markdown": "8.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/estree": "1.0.8",
    "@types/node": "24.12.0",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/eslint-plugin": "1.6.1",
    "astro": "6.4.2",
    "astro-og-canvas": "0.11.1",
    "canvaskit-wasm": "0.41.1",
    "console-fail-test": "0.6.0",
    "eslint": "10.4.0",
    "eslint-doc-generator": "3.6.0",
    "eslint-plugin-eslint-plugin": "7.3.1",
    "eslint-plugin-jsdoc": "63.0.0",
    "eslint-plugin-jsonc": "3.2.0",
    "eslint-plugin-n": "18.0.0",
    "eslint-plugin-node-dependencies": "2.2.0",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-yml": "3.3.0",
    "jiti": "2.7.0",
    "json-schema-to-ts": "3.1.1",
    "knip": "6.14.0",
    "prettier": "3.8.0",
    "prettier-plugin-curly": "0.4.0",
    "prettier-plugin-packagejson": "3.0.0",
    "prettier-plugin-sh": "0.18.0",
    "pretty-quick": "4.2.2",
    "sharp": "0.34.5",
    "simple-git-hooks": "2.13.1",
    "starlight-auto-sidebar": "0.4.0",
    "tsdown": "0.22.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "@eslint/json": ">=1.0.0",
    "eslint": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "@eslint/json": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": "^22.22.2 || >=24.15.0"
  }
}
