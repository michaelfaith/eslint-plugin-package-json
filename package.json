{
  "name": "eslint-plugin-package-json",
  "version": "1.5.0",
  "description": "Rules for consistent, readable, and valid package.json files. 🗂️",
  "homepage": "https://github.com/michaelfaith/eslint-plugin-package-json#readme",
  "bugs": {
    "url": "https://github.com/michaelfaith/eslint-plugin-package-json/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelfaith/eslint-plugin-package-json.git"
  },
  "license": "MIT",
  "contributors": [
    {
      "name": "James Zetlen",
      "email": "zetlen@gmail.com"
    },
    {
      "name": "JoshuaKGoldberg",
      "email": "npm@joshuakgoldberg.com",
      "url": "https://joshuakgoldberg.com"
    },
    {
      "name": "michael faith",
      "url": "https://michael.faith"
    }
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.mts",
      "default": "./lib/index.mjs"
    },
    "./experimental": {
      "types": "./lib/experimental/index.d.mts",
      "default": "./lib/experimental/index.mjs"
    }
  },
  "main": "lib/index.mjs",
  "files": [
    "lib/"
  ],
  "scripts": {
    "build": "tsdown",
    "docs:generate": "pnpm build --no-dts && eslint-doc-generator",
    "format": "prettier .",
    "lint": "eslint . --max-warnings 0",
    "lint:knip": "knip",
    "site:build": "astro build",
    "site:check": "astro check --root site",
    "site:dev": "astro dev",
    "site:preview": "astro preview",
    "site:sync": "astro sync",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@altano/repository-tools": "^2.0.1",
    "change-case": "^5.4.4",
    "detect-indent": "^7.0.2",
    "detect-newline": "^4.0.1",
    "eslint-fix-utils": "~0.4.3",
    "eslint-json-compat-utils": "^0.2.3",
    "jsonc-eslint-parser": "^3.1.0",
    "package-json-validator": "^1.5.0",
    "semver": "^7.7.3",
    "sort-object-keys": "^2.0.0",
    "sort-package-json": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/markdown-satteri": "0.3.3",
    "@astrojs/starlight": "0.41.3",
    "@catppuccin/starlight": "2.1.0",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/js": "10.0.1",
    "@eslint/json": "2.0.0",
    "@eslint/markdown": "8.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/estree": "1.0.8",
    "@types/node": "24.13.0",
    "@types/semver": "7.7.1",
    "@typescript/native": "npm:typescript@7.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/eslint-plugin": "1.6.20",
    "astro": "7.0.6",
    "astro-og-canvas": "0.13.0",
    "canvaskit-wasm": "0.41.1",
    "console-fail-test": "0.6.0",
    "eslint": "10.6.0",
    "eslint-doc-generator": "3.6.0",
    "eslint-plugin-eslint-plugin": "7.4.0",
    "eslint-plugin-jsdoc": "63.0.2",
    "eslint-plugin-jsonc": "3.3.0",
    "eslint-plugin-n": "18.2.1",
    "eslint-plugin-node-dependencies": "2.2.0",
    "eslint-plugin-perfectionist": "5.10.0",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-unicorn": "71.1.0",
    "eslint-plugin-yml": "3.6.0",
    "jiti": "2.7.0",
    "json-schema-to-ts": "3.1.1",
    "knip": "6.25.0",
    "prettier": "3.9.0",
    "prettier-plugin-curly": "0.4.1",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-sh": "0.18.1",
    "pretty-quick": "4.2.2",
    "sharp": "0.35.0",
    "simple-git-hooks": "2.13.1",
    "starlight-auto-sidebar": "0.4.0",
    "tsdown": "0.22.2",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "@eslint/json": ">=1.0.0",
    "eslint": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "@eslint/json": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": "^22.22.2 || >=24.15.0"
  }
}
